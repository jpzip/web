---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.vue';

type Lang = 'ja' | 'en';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'docs' | 'blog';
  ogType?: 'website' | 'article';
  ogImage?: string;
  lang?: Lang;
}

const {
  title,
  description,
  active,
  ogType = 'website',
  ogImage = '/og.png',
  lang = 'ja',
} = Astro.props;

// og:image:type を拡張子から推定 (PNG / JPEG / SVG / WebP)
const imageMime = (() => {
  const ext = ogImage.split('?')[0].split('#')[0].toLowerCase();
  if (ext.endsWith('.png')) return 'image/png';
  if (ext.endsWith('.jpg') || ext.endsWith('.jpeg')) return 'image/jpeg';
  if (ext.endsWith('.webp')) return 'image/webp';
  if (ext.endsWith('.svg')) return 'image/svg+xml';
  return 'image/png';
})();

const t = {
  ja: {
    htmlLang: 'ja',
    ogLocale: 'ja_JP',
    defaultDesc: '登録不要・無料・無制限の郵便番号データセット',
    navPlayground: 'Playground',
    navSdk: 'SDK',
    navDocs: 'Docs',
    navBlog: 'Blog',
    navGithub: 'GitHub',
    navCta: '試す →',
    feedTitle: 'jpzip data releases',
    home: '/',
    docs: '/docs',
    blog: '/blog/',
    playgroundHash: '/#playground',
    codeHash: '/#code',
    altHref: '/en/',
    altHrefDocs: '/en/docs',
    altHrefBlog: '/en/blog/',
    altLabel: 'EN',
    footerTagline:
      '個人開発者・OSS のための、登録不要の郵便番号データセット。日本郵便の公式 API を使えない場面の補完選択肢として。',
    footerData: 'DATA',
    footerSdk: 'SDK',
    footerLinks: 'LINKS',
    footerSpec: 'Spec v1.0',
    footerOther: '+ 他 7 言語',
    footerUsage: '使い方',
    footerGithubOrg: 'GitHub Org',
    footerSpecRepo: 'Spec repo',
    footerJp: '日本郵便',
    footerBlog: 'Blog',
    footerRss: 'Blog RSS',
    footerBlogHref: '/blog/',
    footerRssHref: '/blog/feed.xml',
    footerCopyright: '© 2026 nadai · MIT',
    footerSource: 'data source: 日本郵便 KEN_ALL.csv (Public Domain)',
  },
  en: {
    htmlLang: 'en',
    ogLocale: 'en_US',
    defaultDesc: 'Free, unlimited, no-signup Japanese zipcode dataset',
    navPlayground: 'Playground',
    navSdk: 'SDK',
    navDocs: 'Docs',
    navBlog: 'Blog',
    navGithub: 'GitHub',
    navCta: 'Try it →',
    feedTitle: 'jpzip data releases',
    home: '/en/',
    docs: '/en/docs',
    blog: '/en/blog/',
    playgroundHash: '/en/#playground',
    codeHash: '/en/#code',
    altHref: '/',
    altHrefDocs: '/docs',
    altHrefBlog: '/blog/',
    altLabel: '日本語',
    footerTagline:
      'A no-signup Japanese zipcode dataset for indie devs and OSS — a complement when Japan Post’s official API is not an option.',
    footerData: 'DATA',
    footerSdk: 'SDK',
    footerLinks: 'LINKS',
    footerSpec: 'Spec v1.0',
    footerOther: '+ 7 more languages',
    footerUsage: 'Usage',
    footerGithubOrg: 'GitHub Org',
    footerSpecRepo: 'Spec repo',
    footerJp: 'Japan Post',
    footerBlog: 'Blog',
    footerRss: 'Blog RSS',
    footerBlogHref: '/en/blog/',
    footerRssHref: '/en/blog/feed.xml',
    footerCopyright: '© 2026 nadai · MIT',
    footerSource: 'data source: Japan Post KEN_ALL.csv (Public Domain)',
  },
}[lang];

const desc = description ?? t.defaultDesc;

const site = Astro.site ?? new URL('https://jpzip.nadai.dev');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImageUrl = new URL(ogImage, site).toString();

// hreflang alternates — pathname を JA/EN で対応させる
const path = Astro.url.pathname;
const jaPath = path.startsWith('/en/') ? path.replace(/^\/en\//, '/') : path === '/en' ? '/' : path;
const enPath = path.startsWith('/en/') || path === '/en'
  ? path
  : path === '/'
    ? '/en/'
    : `/en${path}`;
const jaAlt = new URL(jaPath, site).toString();
const enAlt = new URL(enPath, site).toString();

const navLink = (href: string, label: string, key?: string) => ({ href, label, key });
const links = [
  navLink(t.playgroundHash, t.navPlayground, 'playground'),
  navLink(t.codeHash, t.navSdk, 'sdk'),
  navLink(t.docs, t.navDocs, 'docs'),
  navLink(t.blog, t.navBlog, 'blog'),
  navLink('https://github.com/jpzip', t.navGithub),
];

// 言語切替先 — 現在ページに対応する反対言語の URL (pathname から動的に算出)
const altLangHref = lang === 'ja' ? enPath : jaPath;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ja" href={jaAlt} />
    <link rel="alternate" hreflang="en" href={enAlt} />
    <link rel="alternate" hreflang="x-default" href={jaAlt} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OGP -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="jpzip" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content={imageMime} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={t.ogLocale} />
    {lang === 'ja' && <meta property="og:locale:alternate" content="en_US" />}
    {lang === 'en' && <meta property="og:locale:alternate" content="ja_JP" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Feeds & discovery -->
    <link rel="alternate" type="application/rss+xml" title={t.feedTitle} href="/feed.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@500;700;900&family=Noto+Sans+JP:wght@400;500;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // FOUC 防止: テーマを paint 前に反映
      (() => {
        const saved = localStorage.getItem('jpzip-theme');
        const preferred = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = saved || preferred;
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <nav class="site">
      <a class="logo" href={t.home}>
        <span class="logo-mark">郵</span>
        <span class="logo-name">jpzip</span>
      </a>
      <span class="ver-pill">v1.0 · 2026-05</span>
      <details class="nav-drawer">
        <summary class="nav-toggle" aria-label={lang === 'ja' ? 'メニュー' : 'Menu'}>
          <span class="nav-toggle-bars" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
        </summary>
        <div class="nav-links">
          {
            links.map((l) => (
              <a
                href={l.href}
                class={active && l.key === active ? 'active' : ''}
                target={l.href.startsWith('http') ? '_blank' : undefined}
                rel={l.href.startsWith('http') ? 'noopener' : undefined}
              >
                {l.label}
              </a>
            ))
          }
          <a class="lang-switch" href={altLangHref} hreflang={lang === 'ja' ? 'en' : 'ja'}>
            {t.altLabel}
          </a>
          <ThemeToggle client:load />
          <a class="nav-cta" href={t.playgroundHash}>{t.navCta}</a>
        </div>
      </details>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="wrap">
        <div class="foot">
          <div>
            <a class="logo" href={t.home}>
              <span class="logo-mark" style="width:28px;height:28px;font-size:14px;border-radius:8px;">郵</span>
              <span class="logo-name" style="font-size:18px;">jpzip</span>
            </a>
            <p style="max-width: 280px; margin-top: 12px; line-height: 1.7;">
              {t.footerTagline}
            </p>
          </div>
          <div class="foot-col">
            <h4>{t.footerData}</h4>
            <ul>
              <li><a href="https://jpzip.nadai.dev/meta.json">/meta.json</a></li>
              <li><a href="https://jpzip.nadai.dev/g/0.json">/g/&#123;1&#125;.json</a></li>
              <li><a href="https://jpzip.nadai.dev/p/231.json">/p/&#123;3&#125;.json</a></li>
              <li><a href={t.docs}>{t.footerSpec}</a></li>
            </ul>
          </div>
          <div class="foot-col">
            <h4>{t.footerSdk}</h4>
            <ul>
              <li><a href="https://github.com/jpzip/js">TypeScript</a></li>
              <li><a href="https://github.com/jpzip/go">Go</a></li>
              <li><a href="https://github.com/jpzip/python">Python</a></li>
              <li><a href="https://github.com/jpzip/rust">Rust</a></li>
              <li><a href="https://github.com/jpzip/ruby">Ruby</a></li>
              <li><a href="https://github.com/jpzip/dart">Dart</a></li>
              <li><a href="https://github.com/jpzip/php">PHP</a></li>
              <li><a href="https://github.com/jpzip/swift">Swift</a></li>
              <li><a href={`${t.docs}#sdk`}>{t.footerUsage}</a></li>
            </ul>
          </div>
          <div class="foot-col">
            <h4>{t.footerLinks}</h4>
            <ul>
              <li><a href={t.footerBlogHref}>{t.footerBlog}</a></li>
              <li><a href={t.footerRssHref}>{t.footerRss}</a></li>
              <li><a href="https://github.com/jpzip">{t.footerGithubOrg}</a></li>
              <li><a href="https://github.com/jpzip/spec">{t.footerSpecRepo}</a></li>
              <li>
                <a href="https://www.post.japanpost.jp/service/search/zipcode/download/" target="_blank" rel="noopener"
                  >{t.footerJp}</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div class="foot-bottom">
          <span>{t.footerCopyright}</span>
          <span>{t.footerSource}</span>
        </div>
      </div>
    </footer>
  </body>
</html>
