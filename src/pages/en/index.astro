---
import Base from '../../layouts/Base.astro';
import Playground from '../../components/Playground.vue';
import CodeBlock from '../../components/CodeBlock.vue';

// メタ統計は build 時に jpzip.nadai.dev/meta.json から取り、失敗したらデフォルト。
type Meta = {
  version: string;
  total_zipcodes: number;
  prefix_count: number;
};
let meta: Meta = {
  version: '2026-05',
  total_zipcodes: 120677,
  prefix_count: 948,
};
try {
  const res = await fetch('https://jpzip.nadai.dev/meta.json');
  if (res.ok) {
    const m = (await res.json()) as Meta;
    if (m && typeof m.total_zipcodes === 'number') meta = m;
  }
} catch {
  // ビルドホストからネットが通らない環境ではフォールバック
}

const fmt = (n: number) => n.toLocaleString('en-US');

const siteUrl = 'https://jpzip.nadai.dev';

// schema.org Dataset — Google Dataset Search 用 (English)
const datasetLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'jpzip — Japan zipcode dataset',
  alternateName: 'jpzip Japan postal code dataset',
  description:
    'An unofficial Japanese zipcode dataset normalized from Japan Post’s KEN_ALL.csv / KEN_ALL_ROME and served from a CDN. Contains kanji, kana, romaji and MIC municipality codes. Updated monthly. No signup, free, MIT.',
  url: `${siteUrl}/en/`,
  sameAs: ['https://github.com/jpzip', 'https://github.com/jpzip/spec'],
  identifier: `jpzip-${meta.version}`,
  version: meta.version,
  inLanguage: 'en',
  isAccessibleForFree: true,
  license: 'https://opensource.org/licenses/MIT',
  keywords: [
    'zipcode',
    'postal code',
    'japan',
    'KEN_ALL',
    'dataset',
    'CDN',
    'free',
    'no-auth',
    'open data',
  ],
  spatialCoverage: {
    '@type': 'Place',
    name: 'Japan',
    geo: { '@type': 'GeoShape', addressCountry: 'JP' },
  },
  temporalCoverage: meta.version,
  creator: {
    '@type': 'Person',
    name: 'nadai',
    url: 'https://github.com/jpzip',
  },
  isBasedOn: {
    '@type': 'Dataset',
    name: 'Japan Post zipcode data (KEN_ALL.csv)',
    url: 'https://www.post.japanpost.jp/service/search/zipcode/download/',
  },
  variableMeasured: [
    { '@type': 'PropertyValue', name: 'prefecture', description: 'Prefecture name (kanji)' },
    { '@type': 'PropertyValue', name: 'prefecture_kana', description: 'Prefecture name (kana)' },
    { '@type': 'PropertyValue', name: 'prefecture_roma', description: 'Prefecture name (romaji)' },
    { '@type': 'PropertyValue', name: 'prefecture_code', description: 'JIS X 0401 (2 digits)' },
    { '@type': 'PropertyValue', name: 'city', description: 'City / ward name (kanji)' },
    { '@type': 'PropertyValue', name: 'city_kana', description: 'City / ward name (kana)' },
    { '@type': 'PropertyValue', name: 'city_roma', description: 'City / ward name (romaji)' },
    { '@type': 'PropertyValue', name: 'city_code', description: 'MIC municipality code (5 digits)' },
    { '@type': 'PropertyValue', name: 'towns[].town', description: 'Town area (kanji / kana / romaji)' },
  ],
  distribution: [
    {
      '@type': 'DataDownload',
      name: 'meta.json — version and stats',
      encodingFormat: 'application/json',
      contentUrl: `${siteUrl}/meta.json`,
    },
    {
      '@type': 'DataDownload',
      name: '/g/{1}.json — all entries grouped by 1-digit prefix',
      encodingFormat: 'application/json',
      contentUrl: `${siteUrl}/g/0.json`,
    },
    {
      '@type': 'DataDownload',
      name: '/p/{3}.json — all entries grouped by 3-digit prefix',
      encodingFormat: 'application/json',
      contentUrl: `${siteUrl}/p/231.json`,
    },
  ],
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'jpzip',
  url: `${siteUrl}/en/`,
  inLanguage: 'en',
  description: 'Free, unlimited, no-signup Japanese zipcode dataset',
  publisher: { '@type': 'Person', name: 'nadai' },
};

const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: 'jpzip SDK',
  description:
    'Official SDKs for the jpzip dataset. Identical signatures across 8 languages: TypeScript / Go / Python / Rust / Ruby / Dart / PHP / Swift.',
  codeRepository: 'https://github.com/jpzip',
  programmingLanguage: [
    'TypeScript',
    'Go',
    'Python',
    'Rust',
    'Ruby',
    'Dart',
    'PHP',
    'Swift',
  ],
  license: 'https://opensource.org/licenses/MIT',
  author: { '@type': 'Person', name: 'nadai' },
};

// schema.org SoftwareApplication — MCP server for Claude / any MCP client
const mcpServerLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: '@jpzip/mcp-server-jpzip',
  alternateName: 'jpzip MCP server',
  description:
    'A stdio Model Context Protocol server that lets Claude (or any MCP client) look up Japanese postal codes. Exposes four tools: lookup_zipcode, search_by_address, list_cities_in_prefecture, get_metadata.',
  applicationCategory: 'DeveloperApplication',
  applicationSubCategory: 'MCP server',
  operatingSystem: 'Cross-platform (Node.js 18+)',
  url: 'https://github.com/jpzip/mcp',
  downloadUrl: 'https://www.npmjs.com/package/@jpzip/mcp-server-jpzip',
  softwareRequirements: 'Node.js >= 18',
  license: 'https://opensource.org/licenses/MIT',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: 'nadai' },
  isBasedOn: { '@type': 'Dataset', name: 'jpzip', url: siteUrl },
};

const features = [
  {
    icon: '¥',
    title: 'Free forever',
    desc: 'Runs entirely on Cloudflare Pages free tier. ~1,000 files, each under 25 MiB — there is simply no metered axis to bill.',
  },
  {
    icon: '⌖',
    title: 'Offline-ready',
    desc: 'preload({ scope: "all" }) caches the full dataset into the SDK. After that, every lookup works without network.',
    html: true,
  },
  {
    icon: 'A',
    title: 'No signup, no auth',
    desc: 'No API key needed. CORS allows all origins. Fetch directly from the browser.',
  },
  {
    icon: '↻',
    title: 'Monthly auto-updates',
    desc: 'GitHub Actions ingests the latest Japan Post data on the 1st and 15th of each month and redeploys the CDN.',
  },
  {
    icon: 'あ',
    title: 'Kanji, kana, romaji',
    desc: 'KEN_ALL and KEN_ALL_ROME are pre-joined. The MIC municipality code (city_code) is included too.',
  },
  {
    icon: '⚖',
    title: 'MIT & Public Domain',
    desc: 'SDKs are MIT. The data is effectively public domain (Japan Post). Commercial use and redistribution are free.',
  },
];
---

<Base
  title="jpzip — Free, unlimited Japanese zipcode dataset (no signup)"
  description={`A free dataset of every Japanese zipcode (${fmt(meta.total_zipcodes)} entries) served from a CDN. Kanji, kana, romaji and MIC municipality codes included. Usable from 8 language SDKs in 3 lines. MIT.`}
  active="home"
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(mcpServerLd)} />
  </Fragment>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
      <div class="blob b4"></div>
    </div>
    <div class="wrap">
      <div class="hero-inner">
        <div class="eyebrow"><span class="pulse"></span>No signup · Free · Unlimited · MIT</div>
        <h1 class="hero-title">
          Every Japanese zipcode<br />
          <span class="grad">served from a CDN</span>
        </h1>
        <p class="hero-sub">
          A Japan zipcode dataset for indie developers and OSS. <strong>{fmt(meta.total_zipcodes)}</strong>
          normalized entries are delivered from Cloudflare Pages, and each language SDK lets you
          take them all the way offline.
        </p>
        <div class="hero-cta-row">
          <a class="btn-primary" href="#playground">Try it now →</a>
          <a class="btn-ghost" href="https://github.com/jpzip" target="_blank" rel="noopener">↗ GitHub</a>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <div class="n">{fmt(meta.total_zipcodes)}</div>
            <div class="l">Zipcodes</div>
          </div>
          <div class="hero-stat">
            <div class="n">{fmt(meta.prefix_count)}</div>
            <div class="l">3-digit prefixes</div>
          </div>
          <div class="hero-stat">
            <div class="n">10 files</div>
            <div class="l">1-digit groups</div>
          </div>
          <div class="hero-stat">
            <div class="n">¥0</div>
            <div class="l">Forever</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PLAYGROUND -->
  <section class="section pg-section" id="playground">
    <div class="wrap">
      <div class="section-eyebrow"><span class="dot"></span>Playground</div>
      <h2 class="section-title">
        Type 7 digits<br />A real CDN <span class="grad">answers</span>
      </h2>
      <p class="section-desc">
        The form below hits jpzip.nadai.dev directly from your browser. If CORS clears you get real
        data; otherwise a built-in demo response.
      </p>
      <Playground client:visible />
    </div>
  </section>

  <!-- CODE -->
  <section class="section" id="code">
    <div class="wrap">
      <div class="section-eyebrow"><span class="dot"></span>SDK</div>
      <h2 class="section-title">
        A 3-line SDK<br />Same signature <span class="grad">every language</span>
      </h2>
      <p class="section-desc">
        The protocol is fixed, so each SDK is just a few dozen lines — with identical signatures
        across languages.
      </p>
      <CodeBlock client:visible />
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section">
    <div class="wrap">
      <div class="section-eyebrow"><span class="dot"></span>Why jpzip</div>
      <h2 class="section-title">
        Free by design<br /><span class="grad">Hard to break</span>
      </h2>
      <p class="section-desc">No Workers, no R2, no KV. Even at billions of requests, there is no metered axis to bill.</p>

      <div class="features-grid">
        {
          features.map((f) => (
            <article class="feat">
              <div class="feat-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              {f.html ? (
                <p>
                  <code>{`preload({ scope: "all" })`}</code> caches the full dataset into the SDK. After that, every lookup works without network.
                </p>
              ) : (
                <p>{f.desc}</p>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 0;">
    <div class="wrap">
      <div class="cta-box">
        <h2>Three lines <span class="grad">one zipcode lookup</span></h2>
        <p>
          No signup, no API key, no billing surprises. Install from npm (or your language’s package
          manager) and run it in the browser, on a server, or at the edge.
        </p>
        <div class="cta-actions">
          <a class="btn-primary" href="#playground">Try the Playground →</a>
          <a class="btn-ghost" href="https://github.com/jpzip" target="_blank" rel="noopener">View on GitHub ↗</a>
        </div>
      </div>
    </div>
  </section>
</Base>
