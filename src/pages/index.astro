---
import Base from '../layouts/Base.astro';
import Playground from '../components/Playground.vue';
import CodeBlock from '../components/CodeBlock.vue';

// メタ統計は build 時に jpzip.nadai.dev/meta.json から取り、失敗したらデフォルト。
type Meta = {
  version: string;
  total_zipcodes: number;
  prefix_count: number;
};
let meta: Meta = {
  version: '2026-05',
  total_zipcodes: 120677,
  prefix_count: 948,
};
try {
  const res = await fetch('https://jpzip.nadai.dev/meta.json');
  if (res.ok) {
    const m = (await res.json()) as Meta;
    if (m && typeof m.total_zipcodes === 'number') meta = m;
  }
} catch {
  // ビルドホストからネットが通らない環境ではフォールバック
}

const fmt = (n: number) => n.toLocaleString('en-US');

const siteUrl = 'https://jpzip.nadai.dev';

// schema.org Dataset — Google Dataset Search 用
const datasetLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'jpzip — 日本郵便番号データセット',
  alternateName: 'jpzip zipcode dataset',
  description:
    '日本郵便 KEN_ALL.csv / KEN_ALL_ROME を正規化して CDN から配信する非公式の郵便番号データセット。漢字・カナ・ローマ字・総務省コードを含む。月次更新。登録不要・無料・MIT。',
  url: siteUrl,
  sameAs: ['https://github.com/jpzip', 'https://github.com/jpzip/spec'],
  identifier: `jpzip-${meta.version}`,
  version: meta.version,
  inLanguage: 'ja',
  isAccessibleForFree: true,
  license: 'https://opensource.org/licenses/MIT',
  keywords: [
    '郵便番号',
    'zipcode',
    '日本郵便',
    'KEN_ALL',
    'データセット',
    'CDN',
    'free',
    'no-auth',
    'open data',
  ],
  spatialCoverage: {
    '@type': 'Place',
    name: '日本',
    geo: { '@type': 'GeoShape', addressCountry: 'JP' },
  },
  temporalCoverage: meta.version,
  creator: {
    '@type': 'Person',
    name: 'nadai',
    url: 'https://github.com/jpzip',
  },
  isBasedOn: {
    '@type': 'Dataset',
    name: '日本郵便 郵便番号データ (KEN_ALL.csv)',
    url: 'https://www.post.japanpost.jp/service/search/zipcode/download/',
  },
  variableMeasured: [
    { '@type': 'PropertyValue', name: 'prefecture', description: '都道府県名 (漢字)' },
    { '@type': 'PropertyValue', name: 'prefecture_kana', description: '都道府県名 (カナ)' },
    { '@type': 'PropertyValue', name: 'prefecture_roma', description: '都道府県名 (ローマ字)' },
    { '@type': 'PropertyValue', name: 'prefecture_code', description: 'JIS X 0401 (2 桁)' },
    { '@type': 'PropertyValue', name: 'city', description: '市区町村名 (漢字)' },
    { '@type': 'PropertyValue', name: 'city_kana', description: '市区町村名 (カナ)' },
    { '@type': 'PropertyValue', name: 'city_roma', description: '市区町村名 (ローマ字)' },
    { '@type': 'PropertyValue', name: 'city_code', description: '総務省全国地方公共団体コード (5 桁)' },
    { '@type': 'PropertyValue', name: 'towns[].town', description: '町域名 (漢字/カナ/ローマ字)' },
  ],
  distribution: [
    {
      '@type': 'DataDownload',
      name: 'meta.json — バージョンと統計',
      encodingFormat: 'application/json',
      contentUrl: `${siteUrl}/meta.json`,
    },
    {
      '@type': 'DataDownload',
      name: '/g/{1}.json — 1 桁プレフィックス単位の全エントリ',
      encodingFormat: 'application/json',
      contentUrl: `${siteUrl}/g/0.json`,
    },
    {
      '@type': 'DataDownload',
      name: '/p/{3}.json — 3 桁プレフィックス単位の全エントリ',
      encodingFormat: 'application/json',
      contentUrl: `${siteUrl}/p/231.json`,
    },
  ],
};

// schema.org WebSite — sitelink / 検索ボックス対応
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'jpzip',
  url: siteUrl,
  inLanguage: 'ja',
  description: '登録不要・無料・無制限の日本郵便番号データセット',
  publisher: { '@type': 'Person', name: 'nadai' },
};

// schema.org SoftwareSourceCode — SDK 一覧
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: 'jpzip SDK',
  description:
    'jpzip データセットの公式 SDK 群。TypeScript / Go / Python / Rust / Ruby / Java / PHP / Swift / Kotlin / C# / Dart / Elixir / Scala / C / C++ / Perl / R の 15+ 言語で同一シグネチャを提供。',
  codeRepository: 'https://github.com/jpzip',
  programmingLanguage: [
    'TypeScript',
    'Go',
    'Python',
    'Rust',
    'Ruby',
    'Java',
    'PHP',
    'Swift',
    'Kotlin',
    'C#',
    'Dart',
    'Elixir',
    'Scala',
    'C',
    'C++',
    'Perl',
    'R',
  ],
  license: 'https://opensource.org/licenses/MIT',
  author: { '@type': 'Person', name: 'nadai' },
};

const features = [
  {
    icon: '¥',
    title: '永続的に無料',
    desc: 'Cloudflare Pages の無料枠のみで成立。約 1,000 ファイル × 25 MiB 未満、課金軸そのものが存在しない構造。',
  },
  {
    icon: '⌖',
    title: 'オフライン対応',
    desc: 'preload({ scope: "all" }) で全件を SDK にキャッシュ。以降はネットワーク不要で動作。',
    html: true,
  },
  {
    icon: 'A',
    title: '登録・認証なし',
    desc: 'API キー不要。CORS は全オリジン許可。ブラウザから直接 fetch して使えます。',
  },
  {
    icon: '↻',
    title: '月次自動更新',
    desc: '毎月 1 日と 15 日に GitHub Actions が日本郵便の最新データを取り込み、CDN へデプロイ。',
  },
  {
    icon: 'あ',
    title: '漢字・カナ・ローマ字',
    desc: 'KEN_ALL と KEN_ALL_ROME を結合済み。city_code (総務省コード) も付与。',
  },
  {
    icon: '⚖',
    title: 'MIT & Public Domain',
    desc: 'SDK は MIT。データは元データが Public Domain 相当のため、商用利用も再配布も自由。',
  },
];
---

<Base
  title="jpzip — 登録不要・無料・無制限の郵便番号データセット"
  description={`日本の全郵便番号 (${fmt(meta.total_zipcodes)} 件) を CDN から配信する無料データセット。漢字・カナ・ローマ字・総務省コードを含み、15+ 言語の SDK で 3 行から利用可能。MIT。`}
  active="home"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
  </Fragment>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
      <div class="blob b4"></div>
    </div>
    <div class="wrap">
      <div class="hero-inner">
        <div class="eyebrow"><span class="pulse"></span>登録不要 · 無料 · 無制限 · MIT</div>
        <h1 class="hero-title">
          日本の郵便番号を、<br />
          <span class="grad">CDN から配るデータセット。</span>
        </h1>
        <p class="hero-sub">
          個人開発者と OSS のための日本郵便番号データセット。Cloudflare Pages から配信される <strong
            >{fmt(meta.total_zipcodes)}</strong
          > 件の正規化済みデータを、各言語の薄い SDK 経由でオフラインまで持っていける。
        </p>
        <div class="hero-cta-row">
          <a class="btn-primary" href="#playground">いますぐ試す →</a>
          <a class="btn-ghost" href="https://github.com/jpzip" target="_blank" rel="noopener">↗ GitHub</a>
        </div>
        <div style="margin-top: 28px;">
          <div class="install-strip">
            <span class="prompt">$</span>
            <span>npm i jpzip</span>
            <button onclick="navigator.clipboard?.writeText('npm i jpzip')">copy</button>
          </div>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <div class="n">{fmt(meta.total_zipcodes)}</div>
            <div class="l">Zipcodes</div>
          </div>
          <div class="hero-stat">
            <div class="n">{fmt(meta.prefix_count)}</div>
            <div class="l">3桁 Prefix</div>
          </div>
          <div class="hero-stat">
            <div class="n">10 files</div>
            <div class="l">1-digit groups</div>
          </div>
          <div class="hero-stat">
            <div class="n">¥0</div>
            <div class="l">Forever</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PLAYGROUND -->
  <section class="section pg-section" id="playground">
    <div class="wrap">
      <div class="section-eyebrow"><span class="dot"></span>Playground</div>
      <h2 class="section-title">
        7 桁、入れてみる。<br />本物の CDN が、<span class="grad">返事を返す。</span>
      </h2>
      <p class="section-desc">
        下のフォームはブラウザから直接 jpzip.nadai.dev を叩いています。CORS が通れば本物のデータ、通らなければデモ用フォールバックが返ります。
      </p>
      <Playground client:visible />
    </div>
  </section>

  <!-- CODE -->
  <section class="section" id="code">
    <div class="wrap">
      <div class="section-eyebrow"><span class="dot"></span>SDK</div>
      <h2 class="section-title">
        3 行で読める SDK。<br />同じシグネチャ、<span class="grad">どの言語でも。</span>
      </h2>
      <p class="section-desc">
        プロトコル仕様を固定してあるから、SDK の中身は数十行。各言語で同じシグネチャを揃えています。
      </p>
      <CodeBlock client:visible />
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section">
    <div class="wrap">
      <div class="section-eyebrow"><span class="dot"></span>Why jpzip</div>
      <h2 class="section-title">
        構造的に、無料。<br /><span class="grad">壊れにくい設計。</span>
      </h2>
      <p class="section-desc">Worker・R2・KV を一切使わない設計。アクセスが何億あっても課金軸が存在しません。</p>

      <div class="features-grid">
        {
          features.map((f) => (
            <article class="feat">
              <div class="feat-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              {f.html ? (
                <p>
                  <code>{`preload({ scope: "all" })`}</code> で全件を SDK にキャッシュ。以降はネットワーク不要で動作。
                </p>
              ) : (
                <p>{f.desc}</p>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 0;">
    <div class="wrap">
      <div class="cta-box">
        <h2>3 行で、<span class="grad">郵便番号が引ける。</span></h2>
        <p>
          登録不要、API キー不要、課金リスクなし。今すぐ npm でインストールして、ブラウザでもサーバでも動かしてみてください。
        </p>
        <div class="cta-actions">
          <a class="btn-primary" href="#playground">Playground を試す →</a>
          <a class="btn-ghost" href="https://github.com/jpzip" target="_blank" rel="noopener">GitHub で見る ↗</a>
        </div>
      </div>
    </div>
  </section>
</Base>
